{
  "name": "codegraph-toolkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint packages/*/src",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6",
    "vitest": "^4",
    "tsx": "^4",
    "eslint": "^10",
    "prettier": "^3"
  }
}
