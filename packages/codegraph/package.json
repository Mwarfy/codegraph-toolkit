{
  "name": "@liby-tools/codegraph",
  "version": "0.5.0",
  "description": "Visual dependency graph + deterministic synopsis for AI-supervised codebases",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./synopsis": "./dist/synopsis/builder.js",
    "./synopsis/adr-markers": "./dist/synopsis/adr-markers.js",
    "./diff": "./dist/diff/index.js"
  },
  "bin": {
    "codegraph": "dist/cli/index.js",
    "codegraph-datalog-check-fast": "scripts/datalog-check-fast.mjs"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mwarfy/codegraph-toolkit.git",
    "directory": "packages/codegraph"
  },
  "license": "MIT",
  "keywords": [
    "typescript",
    "static-analysis",
    "code-intelligence",
    "codegraph",
    "ai",
    "claude-code",
    "monorepo"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@liby-tools/datalog": "^0.3.0",
    "@liby-tools/salsa": "^0.3.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.3.0",
    "minimatch": "^10.0.0",
    "serve-handler": "^6.1.6",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/serve-handler": "^6.1.4"
  }
}
