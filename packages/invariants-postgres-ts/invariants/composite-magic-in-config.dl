// COMPOSITE-MAGIC-IN-CONFIG (Tier 17).
//
// Pourquoi : un magic number (timeout / threshold) hardcoded dans un
// fichier de config sensible (resource-thresholds, timeout-config,
// env, etc.) viole indirectement ADR-013/015/019. Ces fichiers
// devraient utiliser le resolver typed avec source tracking, pas des
// litteraux.
//
// Source : extractor magic-numbers (existant).
// Fact : MagicNumber(file, line, value, context, category)
//
// Whitelist : 0/1/-1/100 (constants idiomatiques) — non emis par
// l'extractor (skip preconfigure cote extractor).
//
// Pattern ratchet : grandfather par (file, line, value).

.decl MagicInConfigGrandfathered(file: symbol, line: number, value: symbol)
.decl IsConfigFile(file: symbol)
IsConfigFile("sentinel-core/src/shared/timeout-config.ts").
IsConfigFile("sentinel-core/src/shared/resource-thresholds.ts").
IsConfigFile("sentinel-core/src/shared/resource-capabilities.ts").
IsConfigFile("sentinel-core/src/shared/env.ts").
IsConfigFile("sentinel-core/src/shared/constants.ts").
IsConfigFile("sentinel-core/src/config/block-profiles.ts").

Violation("COMPOSITE-MAGIC-IN-CONFIG", F, L,
  "magic number dans fichier config sensible — utiliser resolver typed avec source tracking (ADR-013/015/019)") :-
    MagicNumber(F, L, V, _, _),
    IsConfigFile(F),
    !MagicInConfigGrandfathered(F, L, V).

// Grandfather list — 2026-05-01 (auto-generated, 30 entries).
MagicInConfigGrandfathered("sentinel-core/src/shared/constants.ts", 28, "300000").
