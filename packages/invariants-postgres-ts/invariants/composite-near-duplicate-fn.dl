NearDuplicateFnGrandfathered("packages/codegraph/src/extractors/arguments.ts:iterateFnScopes", "packages/codegraph/src/extractors/boolean-params.ts:iterateFnScopes").
NearDuplicateFnGrandfathered("packages/codegraph/src/extractors/arguments.ts:iterateFnScopes", "packages/codegraph/src/extractors/resource-balance.ts:iterateFnScopes").
NearDuplicateFnGrandfathered("packages/codegraph/src/extractors/arguments.ts:iterateFnScopes", "packages/codegraph/src/extractors/tainted-vars.ts:iterateFnScopes").
