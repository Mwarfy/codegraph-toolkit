    "start": "node dist/index.js"
  },
  "dependencies": {
    "@liby-tools/codegraph": ">=0.6.0",
    "fastify": "^5.2.0",
    "@fastify/websocket": "^11.0.1",
    "@fastify/static": "^8.0.4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.6",
    "tsx": "^4"
  }
