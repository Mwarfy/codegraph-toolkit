{
  "name": "@liby-tools/dashboard-server",
  "version": "0.1.0-alpha.0",
  "description": "Live cockpit server for codegraph-toolkit — graph + tensions + runtime + agent transparency, streamed via WebSocket.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codegraph-dashboard": "dist/index.js"
  },
